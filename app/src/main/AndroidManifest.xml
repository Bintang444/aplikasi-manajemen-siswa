<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.tugaspkl">

    <!-- Izin Internet buat konek ke API PHP -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TugasPKL">

        <!-- Welcome / Launcher -->
        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.main.WelcomeActivity"
            android:exported="true" />

        <!-- Main Activity (yang nampilin fragment2) -->
        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false" />

        <!-- Dashboard activity -->
        <activity android:name=".ui.main.DashboardActivity" />

        <!-- Login -->
        <activity android:name=".ui.auth.LoginActivity" />

        <!-- Lain-lain -->
        <activity android:name=".ui.main.TambahSiswaActivity" />
        <activity android:name=".ui.main.TambahJurusanActivity" />

    </application>
</manifest>