<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7F7"
    android:padding="16dp"
    tools:context=".ui.main.JurusanFragment">

    <!-- Konten -->
    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingTop="20dp">

        <TextView
            android:id="@+id/textView10"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="JURUSAN"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="35dp">

            <EditText
                android:id="@+id/etSearchJurusan"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Cari Nama Jurusan"
                android:background="@drawable/border_edittext"
                android:drawableStart="@drawable/icon_search"
                android:textColor="#000000"
                android:textColorHint="#9E9E9E"
                android:padding="10dp"
                android:layout_marginEnd="10dp"/>

            <Button
                android:id="@+id/btnTambahJurusan"
                android:layout_width="156dp"
                android:layout_height="wrap_content"
                android:backgroundTint="#1F82C8"
                android:text="Tambah Jurusan" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvJurusan"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="20dp"
            android:paddingBottom="0dp" />

    </LinearLayout>
</RelativeLayout>
