<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/spacing_lg"
    android:background="@color/background">

    <!-- Top Action Bar -->
    <LinearLayout
        android:id="@+id/headerTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBackSiswa"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/back_icon"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/app_name" />

        <TextView
            android:id="@+id/tvHeaderSiswa"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/tambah_siswa_title"
            android:textAlignment="center"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_h3"
            android:textStyle="bold"
            android:layout_marginEnd="28dp" />
    </LinearLayout>

    <!-- Scrollable Form Body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerTitle"
        android:layout_marginTop="@dimen/spacing_lg"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- NIS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tambah_siswa_nis"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body_small"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etNIS"
                android:layout_width="match_parent"
                android:layout_height="@dimen/spacing_huge"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_search_input"
                android:hint="@string/tambah_siswa_nis_hint"
                android:paddingHorizontal="@dimen/spacing_md"
                android:textColor="@color/text_secondary"
                android:textColorHint="@color/text_hint"
                android:textSize="@dimen/text_body_small" />

            <!-- NAMA -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/tambah_siswa_nama"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body_small"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etNama"
                android:layout_width="match_parent"
                android:layout_height="@dimen/spacing_huge"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_search_input"
                android:hint="@string/tambah_siswa_nama_hint"
                android:paddingHorizontal="@dimen/spacing_md"
                android:textColor="@color/text_secondary"
                android:textColorHint="@color/text_hint"
                android:textSize="@dimen/text_body_small" />

            <!-- JENIS KELAMIN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/tambah_siswa_jenkel"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body_small"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/spacing_huge"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_search_input">

                <Spinner
                    android:id="@+id/spinnerJenisKelamin"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:paddingHorizontal="12dp" />
            </FrameLayout>

            <!-- JURUSAN -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/tambah_siswa_jurusan"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body_small"
                android:textStyle="bold" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="@dimen/spacing_huge"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_search_input">

                <Spinner
                    android:id="@+id/spinnerJurusan"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:paddingHorizontal="12dp" />
            </FrameLayout>

            <!-- ALAMAT -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/tambah_siswa_alamat"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body_small"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/etAlamat"
                android:layout_width="match_parent"
                android:layout_height="90dp"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_search_input"
                android:gravity="top|start"
                android:hint="@string/tambah_siswa_alamat_hint"
                android:inputType="textMultiLine"
                android:padding="@dimen/spacing_md"
                android:textColor="@color/text_secondary"
                android:textColorHint="@color/text_hint"
                android:textSize="@dimen/text_body_small" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSimpan"
                android:layout_width="match_parent"
                android:layout_height="@dimen/touch_target_min"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="@dimen/spacing_xxl"
                android:backgroundTint="@color/primary"
                android:text="@string/tambah_siswa_simpan"
                android:textAllCaps="false"
                android:textColor="@color/on_primary"
                android:textSize="@dimen/text_body"
                app:cornerRadius="@dimen/radius_button" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>