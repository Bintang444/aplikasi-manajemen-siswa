<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/spacing_lg"
    android:background="@color/background">

    <!-- HEADER -->
    <include
        android:id="@+id/myHeader"
        layout="@layout/activity_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true" />

    <!-- CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/myHeader"
        android:scrollbars="none"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/fragmentDashboard"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Greeting -->
            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_greeting"
                android:textSize="@dimen/text_h3"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="@dimen/spacing_lg" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/dashboard_subtitle"
                android:textSize="@dimen/text_body_small"
                android:textColor="@color/text_muted"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <!-- Top Summary Cards -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="@dimen/spacing_md">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    app:cardCornerRadius="@dimen/radius_card"
                    app:cardElevation="@dimen/elevation_none"
                    app:cardBackgroundColor="@color/card">

                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_myplaces"
                            android:contentDescription="@string/app_name"
                            app:tint="@color/primary_light"
                            android:layout_marginBottom="@dimen/spacing_xs"/>

                        <TextView
                            android:id="@+id/tvJumlahSiswa"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_siswa"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_siswa_desc"
                            android:textSize="@dimen/text_small"
                            android:textColor="@color/text_muted" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_sm"
                    app:cardCornerRadius="@dimen/radius_card"
                    app:cardElevation="@dimen/elevation_none"
                    app:cardBackgroundColor="@color/card">

                    <LinearLayout
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_manage"
                            android:contentDescription="@string/app_name"
                            app:tint="@color/primary_light"
                            android:layout_marginBottom="@dimen/spacing_xs"/>

                        <TextView
                            android:id="@+id/tvJumlahJurusan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_jurusan"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_jurusan_desc"
                            android:textSize="@dimen/text_small"
                            android:textColor="@color/text_muted" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Bottom Menu Cards -->
            <LinearLayout
                android:id="@+id/gridMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="@dimen/spacing_lg">

                <androidx.cardview.widget.CardView
                    android:id="@+id/menuDataSiswa"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    app:cardCornerRadius="@dimen/radius_card"
                    app:cardElevation="@dimen/elevation_none"
                    app:cardBackgroundColor="@color/card"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_agenda"
                            android:contentDescription="@string/app_name"
                            app:tint="@color/warning"
                            android:layout_marginBottom="@dimen/spacing_xs"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_data_siswa"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_data_siswa_desc"
                            android:textSize="@dimen/text_small"
                            android:textColor="@color/text_muted" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/menuJurusan"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_sm"
                    app:cardCornerRadius="@dimen/radius_card"
                    app:cardElevation="@dimen/elevation_none"
                    app:cardBackgroundColor="@color/card"
                    android:foreground="?attr/selectableItemBackground"
                    android:clickable="true"
                    android:focusable="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@android:drawable/ic_menu_sort_by_size"
                            android:contentDescription="@string/app_name"
                            app:tint="@color/success"
                            android:layout_marginBottom="@dimen/spacing_xs"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_data_jurusan"
                            android:textSize="@dimen/text_body"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/dashboard_data_jurusan_desc"
                            android:textSize="@dimen/text_small"
                            android:textColor="@color/text_muted" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Recent Activity Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_marginBottom="@dimen/spacing_sm">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"
                    android:text="@string/dashboard_aktivitas"
                    android:textSize="@dimen/text_body_large"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:text="@string/dashboard_lihat_semua"
                    android:textSize="@dimen/text_caption"
                    android:textColor="@color/primary" />
            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvRecentActivity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <Spinner
                android:id="@+id/spinnerJurusan"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@drawable/bg_search_input"
                android:paddingHorizontal="@dimen/spacing_md"
                android:textSize="@dimen/text_body_small"
                android:spinnerMode="dropdown"
                android:layout_marginTop="@dimen/spacing_xl" />

            <!-- Bar Chart -->
            <com.github.mikephil.charting.charts.BarChart
                android:id="@+id/barChart"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:layout_marginTop="@dimen/spacing_md" />

        </LinearLayout>
    </ScrollView>
</RelativeLayout>
