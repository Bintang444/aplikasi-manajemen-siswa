<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_md"
    card_view:cardCornerRadius="@dimen/radius_card"
    card_view:cardElevation="@dimen/elevation_none"
    card_view:cardBackgroundColor="@color/card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <TextView
            android:id="@+id/tvNama"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            tools:text="Nama Siswa"
            android:textStyle="bold"
            android:textSize="15sp"
            android:textColor="@color/text_primary" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/border"
            android:layout_marginTop="@dimen/spacing_sm" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="@dimen/spacing_sm">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNis"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="NIS: 12345"
                    android:textSize="@dimen/text_body_small"
                    android:textColor="@color/text_tertiary" />

                <TextView
                    android:id="@+id/tvJK"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Jenis Kelamin: "
                    android:textSize="@dimen/text_body_small"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/tvJurusan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="Jurusan: RPL"
                    android:textSize="@dimen/text_body_small"
                    android:textColor="@color/text_tertiary"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvAlamat"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/text_body_small"
                android:textColor="@color/text_tertiary"
                android:gravity="end" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="@color/border"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginBottom="@dimen/spacing_sm" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEdit"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/touch_target_min"
                android:text="@string/item_edit"
                android:textSize="@dimen/text_caption"
                android:textAllCaps="false"
                app:cornerRadius="@dimen/radius_button"
                android:backgroundTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHapus"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/touch_target_min"
                android:text="@string/item_hapus"
                android:textSize="@dimen/text_caption"
                android:textAllCaps="false"
                app:cornerRadius="@dimen/radius_button"
                android:backgroundTint="@color/danger"
                android:layout_marginStart="@dimen/spacing_sm" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
